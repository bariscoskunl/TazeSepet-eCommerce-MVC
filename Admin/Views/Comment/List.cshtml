@using eTicaretUygulamasi.Mvc.App.Data.Entities
@model IEnumerable<ProductCommentEntity>
<!-- Page Heading -->
<h1 class="h3 mb-2 text-gray-800">Yorumlar</h1>
<p class="mb-4">Sistemdeki yorumların listesi.</p>

<!-- DataTales Example -->
<div class="card shadow mb-4">
    <div class="card-header py-3 d-flex justify-content-between align-items-center">
        <h6 class="m-0 font-weight-bold text-primary">Yorum Listesi</h6>
        <a href="/comments/create" class="btn btn-primary btn-sm">
            <i class="fas fa-plus"></i> Yeni Yorum
        </a>
    </div>

    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-bordered" id="usersTable" width="100%" cellspacing="0">
                <thead>
                    <tr>
                        <th>Ürün</th>
                        <th>Ad Soyad</th>
                        <th>Email</th>
                        <th>Rol</th>
                        <th>Oluşturulma Tarihi</th>
                        <th>Durum</th>
                        <th width="120">İşlemler</th>
                    </tr>
                </thead>

                <tbody>
                    <!-- Örnek veri -->
                    @foreach (var comment in Model)
                    {
                        <tr>

                            <td>@comment.Product.DDName</td>
                            <td>@comment.User.FirstName @comment.User.LastName</td>
                            <td>@comment.User.Email</td>
                            <td>@comment.User.Role.Name</td>
                            <td>@comment.CreatedAt.ToString("dd/MM/yyyy")</td>
                            <td>@(comment.IsConfirmed ? "Onaylandı" : "Beklemede")</td>
                            
                            <td>

                                @if (!comment.IsConfirmed)
                                {
                                    @* Onaylanmamışsa: Yeşil buton, Tik ikonu ve "Onayla" yazısı *@
                                    <form asp-controller="Comment" asp-action="Approve" asp-route-id="@comment.Id" method="post" style="display:inline;">
                                        <button type="submit" class="btn btn-success btn-sm">
                                            <i class="fas fa-check"></i> Onayla
                                        </button>
                                    </form>
                                }
                                else
                                {
                                    @* Onaylanmışsa: Gri (disabled) buton, Çarpı ikonu ve "Pasif Hale Getir" yazısı *@
                                    @* Not: Eğer bunu gerçekten pasif yapmak için kullanacaksan 'disabled'ı kaldırıp bir form içine almalısın *@
                                    
                                    <form asp-controller="Comment" asp-action="UnApproved" asp-route-id="@comment.Id" method="post" style="display:inline;">
                                        <button type="submit" class="btn btn-danger btn-sm">
                                            <i class="fa-solid fa-circle-xmark"></i> Pasif Hale Getir
                                        </button>
                                    </form>
                                    
                                }



                            </td>



                        </tr>

                    }


                </tbody>
            </table>
        </div>
    </div>
</div>