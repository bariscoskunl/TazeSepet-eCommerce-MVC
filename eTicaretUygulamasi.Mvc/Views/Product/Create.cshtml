@model ProductCreateViewModel

@{
    ViewData["Title"] = "Yeni Ürün Ekle";
}

<!-- Breadcrumb Section Begin -->
<section class="breadcrumb-section set-bg" data-setbg="https://images.unsplash.com/photo-1556742049-0cfed4f6a45d?w=1200&q=80" style="background-image: url('https://images.unsplash.com/photo-1556742049-0cfed4f6a45d?w=1200&q=80');">
    <div class="container">
        <div class="row">
            <div class="col-lg-12 text-center">
                <div class="breadcrumb__text">
                    <h2>Yeni Ürün Ekle</h2>
                    <div class="breadcrumb__option">
                        <a href="/">Ana Sayfa</a>
                        <a asp-action="MyProducts" asp-controller="Profile">Ürünlerim</a>
                        <span>Ürün Ekle</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
<!-- Breadcrumb Section End -->

<div class="container mt-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow-sm border-0" style="border-radius: 15px; overflow:hidden;">
                <div class="card-header bg-white border-bottom-0 pt-4 pb-0 text-center">
                    <h3 class="font-weight-bold" style="color: #1c1c1c;">Yeni Ürün Bilgileri</h3>
                </div>
                <div class="card-body p-5">
                    <form asp-action="Create" method="post">
                        
                        <div class="checkout__input">
                            <p>Ürün Adı <span>*</span></p>
                            <input asp-for="Name" placeholder="Örn: Organik Elma" />
                            <span asp-validation-for="Name" class="text-danger"></span>
                        </div>

                        <div class="row">
                            <div class="col-lg-6">
                                <div class="checkout__input">
                                    <p>Fiyat (₺) <span>*</span></p>
                                    <input asp-for="Price" type="number" step="0.01" placeholder="0.00" />
                                    <span asp-validation-for="Price" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="col-lg-6">
                                <div class="checkout__input">
                                    <p>Kategori <span>*</span></p>
                                    <select asp-for="CategoryId" class="form-select" style="height: 50px; border: 1px solid #ebebeb; border-radius: 0; padding-left: 20px; font-size: 16px; color: #b2b2b2;" asp-items="@(new SelectList(ViewBag.Categories, "Id", "Name"))">
                                        <option value="">-- Seçiniz --</option>
                                    </select>
                                    <span asp-validation-for="CategoryId" class="text-danger"></span>
                                </div>
                            </div>
                        </div>

                        <div class="checkout__input">
                            <p>Ürün Açıklaması <span>*</span></p>
                            <textarea asp-for="Details" rows="4" style="width: 100%; height: 150px; border: 1px solid #ebebeb; border-radius: 0; padding: 20px; font-size: 16px; color: #b2b2b2;" placeholder="Ürününüzü detaylıca anlatın..."></textarea>
                            <span asp-validation-for="Details" class="text-danger"></span>
                        </div>

                        <div class="mt-4 text-center">
                            <button type="submit" class="site-btn" style="border-radius:30px; border:none;"><i class="fa fa-save"></i> Ürünü Kaydet</button>
                            <a asp-controller="Profile" asp-action="MyProducts" class="site-btn" style="background:#6c757d; border-radius:30px; color:white;"><i class="fa fa-arrow-left"></i> Vazgeç</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
