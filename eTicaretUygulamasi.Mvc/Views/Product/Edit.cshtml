@model eTicaretUygulamasi.Mvc.Models.ProductEditViewModel

@{
    ViewData["Title"] = "Ürün Düzenle";
}

<!-- Breadcrumb Section Begin -->
<section class="breadcrumb-section set-bg" data-setbg="https://images.unsplash.com/photo-1556742049-0cfed4f6a45d?w=1200&q=80" style="background-image: url('https://images.unsplash.com/photo-1556742049-0cfed4f6a45d?w=1200&q=80');">
    <div class="container">
        <div class="row">
            <div class="col-lg-12 text-center">
                <div class="breadcrumb__text">
                    <h2>Ürün Düzenle</h2>
                    <div class="breadcrumb__option">
                        <a href="/">Ana Sayfa</a>
                        <a asp-action="MyProducts" asp-controller="Profile">Ürünlerim</a>
                        <span>Bilgileri Güncelle</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
<!-- Breadcrumb Section End -->

<div class="container mt-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-lg-10">
            <div class="card shadow-sm border-0" style="border-radius: 15px; overflow:hidden;">
                <div class="card-header bg-white border-bottom-0 pt-4 pb-0 text-center">
                    <h3 class="font-weight-bold" style="color: #1c1c1c;">Ürün Bilgileri</h3>
                </div>
                <div class="card-body p-5">

                    @if (ViewBag.ErrorMessage != null)
                    {
                        <div class="alert alert-danger shadow-sm border-0" style="border-radius: 10px;">
                            <i class="fa fa-exclamation-circle"></i> @ViewBag.ErrorMessage
                        </div>
                    }

                    @if (ViewBag.SuccessMessage != null)
                    {
                        <div class="alert alert-success shadow-sm border-0" style="border-radius: 10px;">
                            <i class="fa fa-check-circle"></i> @ViewBag.SuccessMessage
                        </div>
                    }

                    @if (Model != null)
                    {
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <form method="post" asp-action="Edit" asp-controller="Product">
                            <input asp-for="Id" type="hidden" />
                            <input asp-for="SellerId" type="hidden" />

                            <div class="row">
                                <div class="col-lg-6">
                                    <div class="checkout__input">
                                        <p>Ürün Adı <span>*</span></p>
                                        <input asp-for="DDName" placeholder="Ürün adı" />
                                        <span asp-validation-for="DDName" class="text-danger"></span>
                                    </div>
                                </div>
                                <div class="col-lg-6">
                                    <div class="checkout__input">
                                        <p>Fiyat (₺) <span>*</span></p>
                                        <input asp-for="Price" type="number" step="0.01" />
                                        <span asp-validation-for="Price" class="text-danger"></span>
                                    </div>
                                </div>
                            </div>

                            <div class="row">
                                <div class="col-lg-6">
                                    <div class="checkout__input">
                                        <p>Stok Miktarı <span>*</span></p>
                                        <input asp-for="StockAmount" type="number" />
                                        <span asp-validation-for="StockAmount" class="text-danger"></span>
                                    </div>
                                </div>
                                <div class="col-lg-6">
                                    <div class="checkout__input">
                                        <p>Kategori <span>*</span></p>
                                        <select asp-for="CategoryId" class="form-select" style="height: 50px; border: 1px solid #ebebeb; border-radius: 0; padding-left: 20px; font-size: 16px; color: #b2b2b2;">
                                            <option value="">-- Seçin --</option>
                                            @foreach (var cat in ViewBag.Categories)
                                            {
                                                <option value="@cat.Id">@cat.Name</option>
                                            }
                                        </select>
                                        <span asp-validation-for="CategoryId" class="text-danger"></span>
                                    </div>
                                </div>
                            </div>

                            <div class="checkout__input">
                                <p>Detaylar <span>*</span></p>
                                <textarea asp-for="Details" rows="4" style="width: 100%; height: 150px; border: 1px solid #ebebeb; border-radius: 0; padding: 20px; font-size: 16px; color: #b2b2b2;" placeholder="Ürün detayları..."></textarea>
                                <span asp-validation-for="Details" class="text-danger"></span>
                            </div>

                            <div class="mt-4 text-center">
                                <button type="submit" class="site-btn" style="border-radius:30px; border:none;"><i class="fa fa-refresh"></i> Güncelle</button>
                                <a asp-controller="Profile" asp-action="MyProducts" class="site-btn ml-2" style="background:#17a2b8; border-radius:30px; color:white;"><i class="fa fa-list"></i> Ürünlerime Dön</a>
                                <a asp-controller="Home" asp-action="Index" class="site-btn ml-2" style="background:#6c757d; border-radius:30px; color:white;">İptal</a>
                            </div>

                        </form>
                    }

                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}