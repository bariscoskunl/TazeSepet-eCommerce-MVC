@model eTicaretUygulamasi.Mvc.Models.OrderCreateViewModel

@{
    ViewBag.Title = "Siparişi Tamamla";
}

<!-- Breadcrumb Section Begin -->
<section class="breadcrumb-section set-bg" data-setbg="https://images.unsplash.com/photo-1556742049-0cfed4f6a45d?w=1200&q=80" style="background-image: url('https://images.unsplash.com/photo-1556742049-0cfed4f6a45d?w=1200&q=80');">
    <div class="container">
        <div class="row">
            <div class="col-lg-12 text-center">
                <div class="breadcrumb__text">
                    <h2>Siparişi Tamamla</h2>
                    <div class="breadcrumb__option">
                        <a href="/">Ana Sayfa</a>
                        <a asp-action="Edit" asp-controller="Cart">Sepetim</a>
                        <span>Ödeme</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
<!-- Breadcrumb Section End -->

<div class="container mt-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-lg-10">
            <div class="card shadow-sm border-0" style="border-radius: 15px; overflow:hidden;">
                <div class="card-header bg-white border-bottom-0 pt-4 pb-0 text-center">
                    <h3 class="font-weight-bold" style="color: #1c1c1c;">Ödeme ve Teslimat Bilgileri</h3>
                </div>
                <div class="card-body p-5">

                    @if (ViewBag.ErrorMessage != null)
                    {
                        <div class="alert alert-danger shadow-sm border-0" style="border-radius: 10px;">
                            <i class="fa fa-exclamation-circle"></i> @ViewBag.ErrorMessage
                        </div>
                    }

                    @if (Model == null || Model.Items == null || !Model.Items.Any())
                    {
                        <div class="alert alert-info border-0 shadow-sm text-center py-5" style="border-radius: 10px;">
                            <i class="fa fa-shopping-cart text-muted mb-3" style="font-size: 50px;"></i>
                            <h4>Sepetiniz şu an boş.</h4>
                            <a asp-controller="Home" asp-action="Listing" class="site-btn mt-3" style="border-radius:30px;">Alışverişe Başla</a>
                        </div>
                    }
                    else
                    {
                        <div asp-validation-summary="All" class="text-danger mb-3"></div>

                        <form method="post" asp-action="Create" asp-controller="Order">

                            <!-- Sepet Özeti -->
                            <h5 class="fw-bold mb-4 border-bottom pb-2" style="color:#7fad39;"><i class="fa fa-shopping-basket"></i> Sipariş Özeti</h5>
                            <div class="table-responsive mb-4">
                                <table class="table table-hover align-middle mb-0">
                                    <thead class="bg-light">
                                        <tr>
                                            <th class="border-0">Ürün</th>
                                            <th class="border-0 text-center">Birim Fiyat</th>
                                            <th class="border-0 text-center">Adet</th>
                                            <th class="border-0 text-end">Toplam</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var item in Model.Items)
                                        {
                                            <tr>
                                                <td class="font-weight-bold text-dark">@item.ProductName</td>
                                                <td class="text-center font-weight-bold text-muted">₺@item.UnitPrice.ToString("N2")</td>
                                                <td class="text-center">@item.Quantity</td>
                                                <td class="text-end font-weight-bold" style="color: #d9534f;">
                                                    ₺@((item.UnitPrice * item.Quantity).ToString("N2"))
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                    <tfoot>
                                        <tr style="background-color: #f5f5f5;">
                                            <td colspan="3" class="text-end fw-bold fs-5">Genel Toplam:</td>
                                            <td class="text-end fw-bold fs-5" style="color:#7fad39;">₺@Model.TotalPrice.ToString("N2")</td>
                                        </tr>
                                    </tfoot>
                                </table>
                            </div>

                            <!-- Adres Bilgisi -->
                            <h5 class="fw-bold mb-4 mt-5 border-bottom pb-2" style="color:#7fad39;"><i class="fa fa-map-marker"></i> Teslimat Adresi</h5>
                            <div class="checkout__input">
                                <p>Tam Adresiniz <span>*</span></p>
                                <textarea asp-for="Address" rows="4" style="width: 100%; height: 120px; border: 1px solid #ebebeb; border-radius: 0; padding: 20px; font-size: 16px; color: #b2b2b2;" placeholder="Mahalle, sokak, bina no, daire no..."></textarea>
                                <span asp-validation-for="Address" class="text-danger"></span>
                            </div>

                            <!-- Butonlar -->
                            <div class="mt-5 text-center">
                                <a asp-controller="Cart" asp-action="Edit" class="site-btn" style="background:#6c757d; border-radius:30px; color:white;">
                                    <i class="fa fa-arrow-left"></i> Sepete Dön
                                </a>
                                <button type="submit" class="site-btn ml-2" style="border-radius:30px; border:none;">
                                    <i class="fa fa-check"></i> Siparişi Onayla
                                </button>
                            </div>

                        </form>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}