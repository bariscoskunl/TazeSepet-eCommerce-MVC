@model eTicaretUygulamasi.Mvc.Models.OrderDetailsViewModel

@{
    ViewData["Title"] = "Sipariş Detayları";
}

<!-- Breadcrumb Section Begin -->
<section class="breadcrumb-section set-bg" data-setbg="https://images.unsplash.com/photo-1556742049-0cfed4f6a45d?w=1200&q=80" style="background-image: url('https://images.unsplash.com/photo-1556742049-0cfed4f6a45d?w=1200&q=80');">
    <div class="container">
        <div class="row">
            <div class="col-lg-12 text-center">
                <div class="breadcrumb__text">
                    <h2>Sipariş Detayı</h2>
                    <div class="breadcrumb__option">
                        <a href="/">Ana Sayfa</a>
                        <a asp-action="MyOrders" asp-controller="Profile">Siparişlerim</a>
                        <span>Detay</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
<!-- Breadcrumb Section End -->

<div class="container mt-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-lg-10">
            <div class="card shadow-sm border-0" style="border-radius: 15px; overflow:hidden;">
                <div class="card-header bg-white border-bottom-0 pt-4 pb-0 text-center">
                    <i class="fa fa-shopping-bag text-success mb-3" style="font-size: 50px;"></i>
                    <h3 class="font-weight-bold" style="color: #1c1c1c;">Sipariş Özeti (#@Model?.OrderCode)</h3>
                </div>
                <div class="card-body p-5">

                    @if (ViewBag.ErrorMessage != null)
                    {
                        <div class="alert alert-danger shadow-sm border-0" style="border-radius: 10px;">
                            <i class="fa fa-exclamation-circle"></i> @ViewBag.ErrorMessage
                        </div>
                    }

                    @if (TempData["SuccessMessage"] != null)
                    {
                        <div class="alert alert-success shadow-sm border-0" style="border-radius: 10px;">
                            <i class="fa fa-check-circle"></i> @TempData["SuccessMessage"]
                        </div>
                    }

                    @if (Model != null && Model.OrderId > 0)
                    {
                        <!-- Sipariş Bilgileri -->
                        <div class="row mb-5 pb-4 border-bottom">
                            <div class="col-md-6">
                                <h5 class="fw-bold mb-3" style="color:#7fad39;">Genel Bilgiler</h5>
                                <table class="table table-borderless table-sm">
                                    <tr>
                                        <td class="font-weight-bold text-muted" style="width: 140px;">Sipariş No:</td>
                                        <td class="font-weight-bold text-dark">@Model.OrderCode</td>
                                    </tr>
                                    <tr>
                                        <td class="font-weight-bold text-muted">Tarih:</td>
                                        <td class="text-dark">@Model.OrderDate.ToString("dd MMMM yyyy HH:mm")</td>
                                    </tr>
                                    <tr>
                                        <td class="font-weight-bold text-muted">Durum:</td>
                                        <td>
                                            <span class="badge @(Model.Status == "Tamamlandı" ? "bg-success" : (Model.Status == "İptal Edildi" ? "bg-danger" : "bg-warning text-dark"))" style="font-size: 13px; padding: 6px 10px; border-radius: 4px;">
                                                @Model.Status
                                            </span>
                                        </td>
                                    </tr>
                                </table>
                            </div>
                            <div class="col-md-6">
                                <h5 class="fw-bold mb-3" style="color:#7fad39;">Teslimat Bilgileri</h5>
                                <table class="table table-borderless table-sm">
                                    <tr>
                                        <td class="font-weight-bold text-muted" style="width: 140px;">Teslimat Adresi:</td>
                                        <td class="text-dark">@Model.Address</td>
                                    </tr>
                                    <tr>
                                        <td class="font-weight-bold text-muted mt-3">Toplam Tutar:</td>
                                        <td class="font-weight-bold fs-5" style="color: #d9534f;">₺@Model.TotalPrice.ToString("N2")</td>
                                    </tr>
                                </table>
                            </div>
                        </div>

                        <!-- Ürün Listesi -->
                        <h5 class="fw-bold mb-3" style="color:#7fad39;"><i class="fa fa-box"></i> İçerik</h5>
                        <div class="table-responsive mb-4">
                            <table class="table table-hover align-middle mb-0">
                                <thead class="bg-light">
                                    <tr>
                                        <th class="border-0">Ürün</th>
                                        <th class="border-0 text-center">Birim Fiyat</th>
                                        <th class="border-0 text-center">Adet</th>
                                        <th class="border-0 text-end">Toplam</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in Model.Items)
                                    {
                                        <tr>
                                            <td class="font-weight-bold text-dark">@item.ProductName</td>
                                            <td class="text-center font-weight-bold text-muted">₺@item.UnitPrice.ToString("N2")</td>
                                            <td class="text-center">@item.Quantity</td>
                                            <td class="text-end font-weight-bold" style="color: #d9534f;">₺@item.LineTotal.ToString("N2")</td>
                                        </tr>
                                    }
                                </tbody>
                                <tfoot>
                                    <tr style="background-color: #f5f5f5;">
                                        <td colspan="3" class="text-end fw-bold fs-5">Ödenen Tutar:</td>
                                        <td class="text-end fw-bold fs-5" style="color:#7fad39;">₺@Model.TotalPrice.ToString("N2")</td>
                                    </tr>
                                </tfoot>
                            </table>
                        </div>

                        <!-- Butonlar -->
                        <div class="mt-5 text-center">
                            <a asp-controller="Profile" asp-action="MyOrders" class="site-btn" style="background:#6c757d; border-radius:30px; color:white;">
                                <i class="fa fa-arrow-left"></i> Tüm Siparişlerim
                            </a>
                            <a asp-controller="Home" asp-action="Index" class="site-btn ml-2" style="border-radius:30px; border:none;">
                                <i class="fa fa-shopping-bag"></i> Alışverişe Devam Et
                            </a>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>