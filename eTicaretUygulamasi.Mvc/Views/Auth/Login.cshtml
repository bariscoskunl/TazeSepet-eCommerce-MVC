@model LoginViewModel

<style>

    .login-wrapper {
        min-height: 70vh;
        display: flex;
        align-items: center;
        justify-content: center;
        background: #f5f5f5;
    }

    .login-card {
        width: 900px;
        background: #fff;
        border-radius: 10px;
        overflow: hidden;
        box-shadow: 0 15px 40px rgba(0,0,0,0.1);
    }

    .login-left {
        background: url("https://images.unsplash.com/photo-1604719312566-8912e9227c6a?w=800&q=80") center/cover;
        min-height: 500px;
    }

    .login-right {
        padding: 60px;
    }

        .login-right h3 {
            font-weight: 700;
            margin-bottom: 10px;
        }

        .login-right p {
            color: #777;
            margin-bottom: 30px;
        }

    .login-btn {
        width: 100%;
    }

</style>


<section class="login-wrapper">

    <div class="login-card">

        <div class="row g-0">

            <div class="col-lg-6 login-left"></div>

            <div class="col-lg-6">

                <div class="login-right">

                    <h3>Kullanıcı Girişi</h3>
                    <p>Hesabınıza giriş yapın</p>

                    @if(ViewBag.ErrorMessage != null)
                    {
                        <div class="alert alert-danger">
                            @ViewBag.ErrorMessage
                        </div>
                    }

                    <form asp-action="Login" method="post" asp-controller="Auth">

                        <div class="checkout__input">
                            <p>Email <span>*</span></p>
                            <input asp-for="Email" placeholder="Email adresiniz">
                            <span asp-validation-for="Email" class="text-danger"></span>
                        </div>

                        <div class="checkout__input">
                            <p>Şifre <span>*</span></p>
                            <input asp-for="Password" type="password" placeholder="Şifreniz">
                            <span asp-validation-for="Password" class="text-danger"></span>
                        </div>

                        <button type="submit" class="site-btn login-btn">
                            Giriş Yap
                        </button>

                        <div style="margin-top:20px;text-align:center;">
                            <a asp-action="Register" asp-controller="Auth" style="color: #666; font-size: 14px;">Hesabın yok mu? <span style="color: #7fad39; font-weight:700;">Kayıt Ol</span></a>
                        </div>
                        <div style="margin-top:10px; text-align:center;">
                            <a asp-action="ForgotPassword" asp-controller="Auth"
                               style="color: #666; font-size: 14px;">
                                Şifrenizi mi unuttunuz?
                                <span style="color: #7fad39; font-weight:700;">Şifremi Sıfırla</span>
                            </a>
                        </div>

                    </form>

                </div>
            </div>

        </div>

    </div>

</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}