@model RegisterViewModel

<style>
    .register-wrapper {
        min-height: 80vh;
        display: flex;
        align-items: center;
        justify-content: center;
        background: #f5f5f5;
        padding: 50px 0;
    }

    .register-card {
        width: 1000px; /* Rol butonları için biraz genişlettik */
        background: #fff;
        border-radius: 10px;
        overflow: hidden;
        box-shadow: 0 15px 40px rgba(0,0,0,0.1);
    }

    .register-left {
        background: url("https://images.unsplash.com/photo-1472851294608-062f824d29cc?w=800&q=80") center/cover;
        min-height: 650px;
    }

    .register-right {
        padding: 40px 60px;
    }

    /* Rol Seçimi Tasarımı */
    .role-selection {
        display: flex;
        gap: 15px;
        margin-bottom: 25px;
    }

    .role-item {
        flex: 1;
        position: relative;
    }

        .role-item input[type="radio"] {
            display: none; /* Standart yuvarlağı gizle */
        }

    .role-label {
        display: block;
        text-align: center;
        padding: 12px;
        border: 2px solid #ebebeb;
        border-radius: 8px;
        cursor: pointer;
        transition: all 0.3s ease;
        font-weight: 600;
        color: #666;
    }

        .role-label:hover {
            border-color: #7fad39; /* Ogani Green */
            color: #7fad39;
            background: #fafff2;
        }

    /* Seçili durum */
    .role-item input[type="radio"]:checked + .role-label {
        border-color: #7fad39;
        background: #7fad39;
        color: #fff;
    }

    .role-title {
        font-size: 14px;
        color: #1c1c1c;
        margin-bottom: 8px;
        font-weight: 700;
    }

    .register-btn {
        width: 100%;
        margin-top: 10px;
    }
</style>

<section class="register-wrapper">
    <div class="register-card">
        <div class="row g-0">
            <div class="col-lg-5 register-left"></div>

            <div class="col-lg-7">
                <div class="register-right">
                    <h3>Yeni Hesap Oluştur</h3>
                    <p>Size uygun hesap türünü seçerek başlayın.</p>
                    @if (ViewBag.ErrorMessage != null)
                    {
                        <div class="alert alert-danger">
                            @ViewBag.ErrorMessage
                        </div>
                    }
                    @if (ViewBag.SuccessMessage != null)
                    {
                        <div class="alert alert-success">
                            @ViewBag.SuccessMessage
                        </div>
                    }
                    

                    <form asp-action="Register" method="post" asp-controller="Auth">

                        @* <div class="role-container">
                            <p class="role-title">Hesap Türü <span>*</span></p>
                            <div class="role-selection">
                                <div class="role-item">
                                    <input type="radio" asp-for="RoleId" value="3" id="roleBuyer" checked>
                                    <label for="roleBuyer" class="role-label">Alıcıyım</label>
                                </div>
                                <div class="role-item">
                                    <input type="radio" asp-for="RoleId" value="2" id="roleSeller">
                                    <label for="roleSeller" class="role-label">Satıcıyım</label>
                                </div>
                            </div>
                            <span asp-validation-for="RoleId" class="text-danger"></span>
                        </div> *@

                        <div class="checkout__input">
                            <p>Ad  <span>*</span></p>
                            <input asp-for="FirstName" placeholder="Adınız">
                            <span asp-validation-for="FirstName" class="text-danger"></span>
                        </div>

                        <div class="checkout__input">
                            <p>Soyad  <span>*</span></p>
                            <input asp-for="LastName" placeholder="Soyadınız">
                            <span asp-validation-for="LastName" class="text-danger"></span>
                        </div>

                        <div class="checkout__input">
                            <p>Email <span>*</span></p>
                            <input asp-for="Email" placeholder="Email adresiniz">
                            <span asp-validation-for="Email" class="text-danger"></span>
                        </div>

                        <div class="row">
                            <div class="col-lg-6">
                                <div class="checkout__input">
                                    <p>Şifre <span>*</span></p>
                                    <input asp-for="Password" type="password" placeholder="Şifreniz">
                                    <span asp-validation-for="Password" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="col-lg-6">
                                <div class="checkout__input">
                                    <p>Tekrar <span>*</span></p>
                                    <input asp-for="ConfirmPassword" type="password" placeholder="Tekrar">
                                    <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                                </div>
                            </div>
                        </div>

                        <button type="submit" class="site-btn register-btn">
                            Hemen Kayıt Ol
                        </button>

                        <div style="margin-top:20px; text-align:center;">
                            <a asp-action="Login" asp-controller="Auth" style="color: #666; font-size: 14px;">Zaten bir hesabınız var mı? <span style="color: #7fad39; font-weight:700;">Giriş Yap</span></a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}