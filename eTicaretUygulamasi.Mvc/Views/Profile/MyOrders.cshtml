@model IEnumerable<MyOrdersViewModel>


@{
    ViewData["Title"] = "Siparişlerim";
}

<!-- Breadcrumb Section Begin -->
<section class="breadcrumb-section set-bg" data-setbg="https://images.unsplash.com/photo-1556742049-0cfed4f6a45d?w=1200&q=80" style="background-image: url('https://images.unsplash.com/photo-1556742049-0cfed4f6a45d?w=1200&q=80');">
    <div class="container">
        <div class="row">
            <div class="col-lg-12 text-center">
                <div class="breadcrumb__text">
                    <h2>Sipariş Geçmişim</h2>
                    <div class="breadcrumb__option">
                        <a href="/">Ana Sayfa</a>
                        <a asp-action="Details" asp-controller="Profile">Hesabım</a>
                        <span>Siparişlerim</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
<!-- Breadcrumb Section End -->

<div class="container mt-5 mb-5">
    <div class="card shadow-sm border-0" style="border-radius: 15px; overflow:hidden;">
        <div class="card-body p-4">
            @if (!Model.Any())
            {
                <div class="text-center py-5">
                    <i class="fa fa-shopping-bag text-muted mb-3" style="font-size: 50px;"></i>
                    <h4 class="text-muted">Henüz hiç siparişiniz bulunmamaktadır.</h4>
                    <a asp-action="Listing" asp-controller="Home" class="site-btn mt-3" style="border-radius:30px;">Alışverişe Başla</a>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="bg-light">
                            <tr>
                                <th class="border-0">Sipariş No</th>
                                <th class="border-0">Tarih</th>
                                <th class="border-0">Toplam Tutar</th>
                                <th class="border-0">Durum</th>
                                <th class="border-0 text-center">İşlemler</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var order in Model)
                            {
                                <tr>
                                    <td class="font-weight-bold text-dark">#@order.OrderId</td>
                                    <td class="text-muted">@order.OrderDate.ToString("dd MMM yyyy HH:mm")</td>
                                    <td class="font-weight-bold" style="color: #d9534f;">@order.TotalPrice.ToString("C2")</td>
                                    <td>
                                        <span class="badge @(order.Status == "Tamamlandı" ? "bg-success" : (order.Status == "İptal Edildi" ? "bg-danger" : "bg-warning text-dark"))" style="font-size: 13px; padding: 6px 10px; border-radius: 4px;">
                                            @order.Status
                                        </span>
                                    </td>
                                    <td class="text-center">
                                        <a asp-action="Details" asp-controller="Order" asp-route-id="@order.OrderId" class="btn btn-sm btn-outline-info" style="border-radius: 20px; padding: 4px 15px;">
                                            <i class="fa fa-eye"></i> İncele
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>