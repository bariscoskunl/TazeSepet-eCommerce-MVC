@model IEnumerable<MyProductsViewModel>

<!-- Breadcrumb Section Begin -->
<section class="breadcrumb-section set-bg" data-setbg="https://images.unsplash.com/photo-1556742049-0cfed4f6a45d?w=1200&q=80" style="background-image: url('https://images.unsplash.com/photo-1556742049-0cfed4f6a45d?w=1200&q=80');">
    <div class="container">
        <div class="row">
            <div class="col-lg-12 text-center">
                <div class="breadcrumb__text">
                    <h2>Ürünlerim</h2>
                    <div class="breadcrumb__option">
                        <a href="/">Ana Sayfa</a>
                        <a asp-action="Details" asp-controller="Profile">Hesabım</a>
                        <span>Ürün Yönetimi</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
<!-- Breadcrumb Section End -->

<div class="container mt-5 mb-5">
    <div class="card shadow-sm border-0" style="border-radius: 15px; overflow:hidden;">
        <div class="card-body p-4">
            
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h4 class="font-weight-bold" style="color:#1c1c1c;">Satışta Olan Ürünlerim</h4>
                <a href="/Product/Create" class="site-btn" style="border-radius: 30px;"><i class="fa fa-plus"></i> YENİ ÜRÜN EKLE</a>
            </div>

            @if (!Model.Any())
            {
                <div class="text-center py-5">
                    <i class="fa fa-box-open text-muted mb-3" style="font-size: 50px;"></i>
                    <h4 class="text-muted">Henüz hiç ürün eklememişsiniz.</h4>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="bg-light">
                            <tr>
                                <th class="border-0">Ürün Adı</th>
                                <th class="border-0">Fiyat</th>
                                <th class="border-0 text-center">Stok</th>
                                <th class="border-0 text-center">Durum</th>
                                <th class="border-0 text-center">İşlemler</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td class="font-weight-bold text-dark">
                                        @item.ProductName
                                    </td>
                                    <td class="font-weight-bold" style="color: #d9534f;">
                                        @item.Price.ToString("C2")
                                    </td>
                                    <td class="text-center">
                                        <span class="badge @(item.StockQuantity > 10 ? "bg-success" : (item.StockQuantity > 0 ? "bg-warning text-dark" : "bg-danger"))" style="font-size: 14px; padding: 6px 10px; border-radius: 4px;">
                                            @item.StockQuantity Adet
                                        </span>
                                    </td>
                                    <td class="text-center">
                                        @if (item.Enabledd && item.StockQuantity > 0)
                                        {
                                            <span class="badge bg-primary" style="font-size: 12px; padding: 5px 8px;"><i class="fa fa-check-circle"></i> Aktif</span>
                                        }
                                        else if (item.StockQuantity == 0)
                                        {
                                            <span class="badge bg-danger" style="font-size: 12px; padding: 5px 8px;"><i class="fa fa-times-circle"></i> Stok Bitti</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary" style="font-size: 12px; padding: 5px 8px;"><i class="fa fa-eye-slash"></i> Pasif</span>
                                        }
                                    </td>
                                    <td class="text-center">
                                        <div class="btn-group" role="group">
                                            <a href="/Product/Edit/@item.ProductId" class="btn btn-sm btn-outline-info" title="Düzenle">
                                                <i class="fa fa-edit"></i>
                                            </a>
                                            <a href="/Product/Delete/@item.ProductId" class="btn btn-sm btn-outline-danger" title="Sil">
                                                <i class="fa fa-trash"></i>
                                            </a>
                                            
                                            @if (item.Enabledd && item.StockQuantity > 0)
                                            {
                                                <form method="post" asp-action="Pasive" asp-controller="Product" asp-route-id="@item.ProductId" style="display:inline; margin-left: 5px;">                                                
                                                    <button type="submit" class="btn btn-sm btn-outline-warning" title="Pasif Yap">
                                                        <i class="fa fa-eye-slash"></i>
                                                    </button>
                                                </form>
                                            }
                                            else
                                            {
                                                <form method="post" asp-action="Active" asp-controller="Product" asp-route-id="@item.ProductId" style="display:inline; margin-left: 5px;">                                                
                                                    <button type="submit" class="btn btn-sm btn-outline-success" title="Aktif Yap" @(item.StockQuantity == 0 ? "disabled" : "")>
                                                        <i class="fa fa-check"></i>
                                                    </button>
                                                </form>                
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>