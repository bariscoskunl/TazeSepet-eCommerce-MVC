@{
    ViewData["Title"] = "Hakkımızda";
}
<section class="hero hero-normal">
    <div class="container">
        <div class="row">
            <div class="col-lg-3">
                <partial name="_CategoriesPartial" />
            </div>
            <div class="col-lg-9">
                <div class="hero__search">
                    <div class="hero__search__phone">
                        <div class="hero__search__phone__icon">
                            <i class="fa fa-phone"></i>
                        </div>
                        <div class="hero__search__phone__text">
                            <h5>+90 212 888 88 88</h5>
                            <span>7/24 destek hattı</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
<section class="breadcrumb-section set-bg" data-setbg="https://images.unsplash.com/photo-1556742049-0cfed4f6a45d?w=1200&q=80" style="background-image: url('https://images.unsplash.com/photo-1556742049-0cfed4f6a45d?w=1200&q=80');">
    <div class="container">
        <div class="row">
            <div class="col-lg-12 text-center">
                <div class="breadcrumb__text">
                    <h2>Hakkımızda</h2>
                    <div class="breadcrumb__option">
                        <a asp-controller="Home" asp-action="Index">Ana Sayfa</a>
                        <span>Hakkımızda</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
<section class="about spad">
    <div class="container">
        <div class="row">
            <div class="col-lg-6">
                <div class="about__pic">
                    <img src="/img/about.jpg" alt="">
                </div>
            </div>
            <div class="col-lg-6">
                <div class="about__text">
                    <div class="section-title">
                        <span>Mağazamız Hakkında</span>
                        <h2>Kaliteli ve Güvenilir Alışveriş</h2>
                    </div>
                    <p>
                        Geniş ürün yelpazemiz ile elektronikten giyime, ev eşyalarından kitaplara kadar
                        ihtiyacınız olan her şeyi uygun fiyatlarla sunuyoruz.
                    </p>
                    <p>
                        Müşteri memnuniyetini ön planda tutan ekibimiz, hızlı teslimat ve güvenli ödeme
                        seçenekleri ile yanınızda. Kaliteli ürünler, uygun fiyatlar ve güvenilir hizmet
                        anlayışımızla alışverişin keyfini çıkarın.
                    </p>
                </div>
            </div>
        </div>
    </div>
</section>
<section class="feature spad">
    <div class="container">
        <div class="row">
            <div class="col-lg-4 col-md-6">
                <div class="feature__item">
                    <i class="fa fa-truck"></i>
                    <h5>Ücretsiz Kargo</h5>
                    <p>99 TL üzeri tüm siparişlerde ücretsiz teslimat</p>
                </div>
            </div>
            <div class="col-lg-4 col-md-6">
                <div class="feature__item">
                    <i class="fa fa-shield"></i>
                    <h5>Güvenli Ödeme</h5>
                    <p>256-bit SSL şifreleme ile güvenli alışveriş</p>
                </div>
            </div>
            <div class="col-lg-4 col-md-6">
                <div class="feature__item">
                    <i class="fa fa-headphones"></i>
                    <h5>7/24 Destek</h5>
                    <p>Her zaman yanınızdayız, bize ulaşın</p>
                </div>
            </div>
        </div>
    </div>
</section>